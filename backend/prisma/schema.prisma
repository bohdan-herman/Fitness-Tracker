datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}


model User {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  password  String
  createdAt DateTime  @default(now())
  workouts  Workout[]
}

model Exercise {
  id        Int      @id @default(autoincrement())
  name      String
  workoutId Int
  workout   Workout  @relation(fields: [workoutId], references: [id])
}

model Workout {
  id        Int        @id @default(autoincrement())
  name      String
  exercises Exercise[]
  users     User[]
}